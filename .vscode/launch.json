{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "coreclr",
        "request": "launch",
        "name": "Debug StpFoodBlazor",
        "program": "${workspaceFolder}/StpFoodBlazor/bin/Debug/net8.0/StpFoodBlazor.dll",
        "args": [],
        "cwd": "${workspaceFolder}/StpFoodBlazor",
        "stopAtEntry": false,
        "serverReadyAction": {
          "action": "openExternally",
          "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
        },
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "APPCONFIG__SHEETID": "${env:APPCONFIG__SHEETID}",
          "APPCONFIG__SHEETSURL": "${env:APPCONFIG__SHEETSURL}",
          "APPCONFIG__HOLIDAYURL": "${env:APPCONFIG__HOLIDAYURL}",
          "APPCONFIG__CACHEINVALIDATIONKEY": "${env:APPCONFIG__CACHEINVALIDATIONKEY}",
          "APPCONFIG__KEYVAULTURL": "${env:APPCONFIG__KEYVAULTURL}"
        },
        "preLaunchTask": "build"
      }
    ]
  }