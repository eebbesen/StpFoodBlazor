@using StpFoodBlazor.Helpers
@using StpFoodBlazor.Models
@using StpFoodBlazor.Services
@using Microsoft.JSInterop
@implements IDisposable
@inherits LayoutComponentBase
@inject NavigationManager NavMan
@inject IHolidayService HolidayServiceImpl
@inject IGiftCardService GiftCardServiceImpl
@inject ILogger<MainLayout> Logger
@inject IJSRuntime JS

<div class="page">
    <main>
        <nav class="top-row px-4" id="navbar" aria-label="Primary navigation">
            <div class="container d-md-flex" id="navbar-items">
                <div id="messages" class="marquee-container d-none d-md-block" aria-live="off" aria-atomic="true">
                    <div class="marquee-inner">
                        @RenderHolidayStrings()
                        @RenderHolidayStrings()
                    </div>
                </div>
                <div class="d-flex" id="nav-links" style="align-items: center;">
                    <a id="root-nav" href="/" class=@(classValuesPosition("")) aria-current=@(IsCurrentPage("") ? "page" : null)>Deals</a>
                    <a id="giftcard-nav" href="giftcards" class=@(classValuesPosition("giftcards") + " position-relative") aria-current=@(IsCurrentPage("giftcards") ? "page" : null)>Gift Cards
                        @if(giftCards.Length > 0)
                        {
                            <span id="giftcards-exist" class="position-absolute top-0 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">Active gift card deals available</span>
                            </span>
                        }
                    </a>
                    <a id="about-nav" href="about" class=@(classValuesPosition("about")) aria-current=@(IsCurrentPage("about") ? "page" : null)>About</a>
                    <button id="theme-toggle"
                            type="button"
                            class="btn btn-link theme-toggle"
                            @onclick="ToggleThemeAsync"
                            aria-label="@ThemeToggleAriaLabel"
                            aria-pressed="@isDarkMode.ToString().ToLower()">
                        <span class="theme-toggle-icon" aria-hidden="true">@ThemeToggleIcon</span>
                    </button>
                </div>
            </div>
        </nav>

        <article class="content px-4" id="main-content" tabindex="-1">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" role="alert" aria-live="assertive">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <button class="dismiss" aria-label="Dismiss error">🗙</button>
</div>

@code {
    private HolidayDisplay[] holidayStrings = Array.Empty<HolidayDisplay>();
    private GiftCard[] giftCards = Array.Empty<GiftCard>();
    private bool initialized = false;
    private bool isDarkMode;
    private bool isThemeInitialized;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        NavMan.LocationChanged += OnLocationChanged;

        if (initialized)
        {
            return;
        }

        try
        {
            giftCards = await GiftCardServiceImpl.GetGiftCardsAsync();
            var today = DateTime.Now;
            var twoMoreDays = today.AddDays(2);
            Dictionary<string, string[]> holidayData = await HolidayServiceImpl.GetHolidaysRangeAsync(
                today.ToString("MM-dd"),
                twoMoreDays.ToString("MM-dd"));
            holidayStrings = Helper.BuildHolidayStrings(holidayData);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching holidays.");
        }
        initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || isThemeInitialized)
        {
            return;
        }

        try
        {
            isDarkMode = await JS.InvokeAsync<bool>("themeManager.initialize");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to initialize theme manager.");
            isDarkMode = false;
        }

        isThemeInitialized = true;
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavMan.LocationChanged -= OnLocationChanged;
    }

    private async Task ToggleThemeAsync()
    {
        try
        {
            isDarkMode = await JS.InvokeAsync<bool>("themeManager.toggle");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to toggle theme.");
        }
    }

    private string CurrentPage() => NavMan.ToBaseRelativePath(NavMan.Uri).Split('?')[0];

    private bool IsCurrentPage(string uriTest) => uriTest == CurrentPage();

    private string classValuesPosition(string uriTest)
    {
        var current = CurrentPage();

        if (uriTest == current)
        {
            return " d-none";
        }

        if (((current == "giftcards" || current == "") && uriTest == "about") ||
        (current == "about" && uriTest == "giftcards"))
        {
            return " justify-content-end";
        }

        return " flex-fill";
    }

    private RenderFragment RenderHolidayStrings() => builder =>
    {
        foreach (var holiday in holidayStrings)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "holiday m-auto p-3");
            builder.OpenElement(2, "strong");
            builder.AddContent(3, holiday.DateText);
            builder.AddContent(4, ":");
            builder.CloseElement();
            builder.AddContent(5, " ");
            builder.AddContent(6, holiday.HolidayNames);
            builder.CloseElement();
        }

        // Add separator only if there are holidays
        if (holidayStrings.Length > 0)
        {
            builder.OpenElement(7, "img");
            builder.AddAttribute(8, "src", "/favicon.png");
            builder.AddAttribute(9, "alt", "separator");
            builder.AddAttribute(10, "class", "holiday-separator");
            builder.CloseElement();
        }
    };

    private string ThemeToggleIcon => isDarkMode ? "☀️" : "🌙";

    private string ThemeToggleAriaLabel => isDarkMode ? "Switch to light mode" : "Switch to dark mode";
}
